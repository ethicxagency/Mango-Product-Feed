{
  "name": "mango-product-feed",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "dev:local": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "setup": "prisma generate && prisma migrate deploy && prisma db seed",
    "setup:prod": "prisma generate && prisma db push",
    "render-start": "node scripts/check-production-env.mjs && npm run setup:prod && npm run start",
    "docker-start": "npm run setup && npm run start",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "shopify": "shopify",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "prisma": "prisma",
    "typecheck": "react-router typegen && tsc --noEmit",
    "db:seed": "prisma db seed",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "isbot": "^5.1.31",
    "nodemailer": "^7.0.5",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite-tsconfig-paths": "^6.0.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
