# Database (PostgreSQL required in production)
DATABASE_URL="postgresql://mango:mango@localhost:5432/mango_feed"

# Application
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Shopify (required for embedded app mode)
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SCOPES="read_products,write_products,read_inventory,read_content"
SHOPIFY_APP_URL="http://localhost:3000"
LOCAL_SHOP_ID="local-shop"

# Admin panel
ADMIN_EMAIL="admin@mango-feed.app"
ADMIN_PASSWORD="changeme"

# AI (optional)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Email notifications (optional — logs to console when unset)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@mango-feed.app"

# Security
RATE_LIMIT_PER_MINUTE="120"
